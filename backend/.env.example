# ── Server
PORT=5000

# ── CORS: comma-separated list of allowed frontend origins
# Local development: http://127.0.0.1:5500,http://localhost:5500
# Production: https://yourdomain.com
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# ── Gmail (Nodemailer)
# Your Gmail address
EMAIL_USER=your_email@gmail.com
# Gmail App Password (NOT your Gmail login password)
# Generate at: https://myaccount.google.com/apppasswords
APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Fast2SMS
# Get your API key at: https://www.fast2sms.com/dashboard/credentials
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ── Your mobile number (10 digits, no country code)
PHONE_NUMBER=9876543210
